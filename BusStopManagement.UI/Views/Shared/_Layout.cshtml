@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Bus Stops Management</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Link to your new CSS -->
    <link href="~/templatemo-personal-style.css" rel="stylesheet" />

    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
    <!-- Navigation -->
    <nav id="mainNav">
        <div class="nav-container">
            <div class="logo">
                <i class="fa fa-bus"></i> Bus Stops
            </div>
            <ul class="nav-links">
                @* <li><a asp-controller="BusStop" asp-action="Index">All Bus Stops</a></li>
                <li><a asp-controller="BusStop" asp-action="Create">Add Bus Stop</a></li>
                <li><a asp-controller="BusStop" asp-action="Search">Search Bus Stops</a></li> *@
                <li><a asp-controller="Account" asp-action="Login">Login</a></li>
            </ul>
            <div class="mobile-menu-toggle" id="menuToggle">
                <div class="hamburger"></div>
                <div class="hamburger"></div>
                <div class="hamburger"></div>
            </div>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div class="mobile-menu" id="mobileMenu">
        <ul class="mobile-nav-links">
            @* <li><a asp-controller="BusStop" asp-action="Index">All Bus Stops</a></li>
            <li><a asp-controller="BusStop" asp-action="Create">Add Bus Stop</a></li>
            <li><a asp-controller="BusStop" asp-action="Search">Search Bus Stops</a></li> *@
            <li><a asp-controller="Account" asp-action="Login">Login</a></li>
        </ul>
    </div>

    <!-- Hero Section -->
    <section class="hero">
        <div class="floating-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
            <div class="shape shape-4"></div>
            <div class="shape shape-5"></div>
            <div class="shape shape-6"></div>
        </div>
        <div class="hero-content">
            <p class="hero-subtitle">Smart Transport System</p>
            <h1>Bus Stops Management</h1>
            <p class="subtitle">Manage, search, and optimize bus stops with ease.</p>
            <a href="@Url.Action("Index", "BusStop")" class="cta-button">Get Started</a>
        </div>
        <div class="scroll-indicator"></div>
    </section>

    <!-- Main Content -->
    <main class="page-content">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-left">
                <p>&copy; @DateTime.Now.Year Bus Stops Management System</p>
            </div>
            <div class="footer-right">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">Contact</a>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    @RenderSection("Scripts", required: false)

    <script>
        // Mobile menu toggle
        const menuToggle = document.getElementById("menuToggle");
        const mobileMenu = document.getElementById("mobileMenu");

        menuToggle.addEventListener("click", () => {
            menuToggle.classList.toggle("active");
            mobileMenu.classList.toggle("active");
        });

        // Add scroll effect to nav
        window.addEventListener("scroll", () => {
            const nav = document.getElementById("mainNav");
            if (window.scrollY > 50) {
                nav.classList.add("scrolled");
            } else {
                nav.classList.remove("scrolled");
            }
        });
    </script>
</body>
</html>
